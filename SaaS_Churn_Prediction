    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "xxkqiCZYl0lu"
      },
      "source": [
        "## 4.1 Design Rationale\n",
        "We build a **monthly snapshot table** — one row per (account, month). For each snapshot date `D`:\n",
        "- **Lookback window**: all data before `D` (to avoid leakage)\n",
        "- **Target**: did account churn within next 30 days after `D`?\n",
        "- **Rich features**: 20+ engineered signals covering recency, frequency, revenue, support & lifecycle\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 70,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "rwb9oOohl0lu",
        "outputId": "5760800f-6a36-43a9-98fd-8350d61eae53"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Tables indexed and grouped for fast feature extraction.\n",
            "EVENT_COL = 'usage_count' | submit_col = 'submitted_at' | resolve_col = 'closed_at'\n",
            "sat_col = 'satisfaction_score' | escalate_col = 'escalation_flag'\n"
          ]
        }
      ],
      "source": [
        "from dateutil.relativedelta import relativedelta\n",
        "import numpy as np\n",
        "\n",
        "DATASET_END = pd.Timestamp('2025-01-01')\n",
        "PREDICTION_WINDOW = 30  # days\n",
        "\n",
        "# ── Pre-index tables for fast lookup ──────────────────────────\n",
        "df2_idx   = df2_clean.set_index('account_id')\n",
        "df3_idx   = df3_clean.set_index('account_id')\n",
        "df4_idx   = df4_clean.set_index('account_id')\n",
        "\n",
        "# Sort for efficient slicing\n",
        "df2_sorted = df2_clean.sort_values(['account_id', 'start_date'])\n",
        "df3_sorted = df3_clean.sort_values(['account_id', 'usage_date'])\n",
        "df4_sorted = df4_clean.sort_values(['account_id', submit_col])\n",
        "\n",
        "# Pre-group for O(1) lookup\n",
        "df2_grp = df2_sorted.groupby('account_id')\n",
        "df3_grp = df3_sorted.groupby('account_id')\n",
        "df4_grp = df4_sorted.groupby('account_id')\n",
        "\n",
        "print(\"Tables indexed and grouped for fast feature extraction.\")\n",
        "print(f\"EVENT_COL = '{EVENT_COL}' | submit_col = '{submit_col}' | resolve_col = '{resolve_col}'\")\n",
        "print(f\"sat_col = '{sat_col}' | escalate_col = '{escalate_col}'\")\n"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "8SboFkbVl0lu"
      },
      "source": [
        "## 4.2 Feature Extraction Functions"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 71,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "_VRcaN8wl0lu",
        "outputId": "5b68f93c-049c-4b34-ce39-ca1c469d76d2"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ All 3 feature functions defined (subscription, usage, support).\n",
            "   Subscription features: 8\n",
            "   Usage features: 10\n",
            "   Support features: 9\n",
            "   Account static features: 6\n",
            "   Total features: ~33\n"
          ]
        }
      ],
      "source": [
        "def subscription_features(account_id, D):\n",
        "    \"\"\"Revenue & plan features up to snapshot date D.\"\"\"\n",
        "    try:\n",
        "        subs = df2_grp.get_group(account_id)\n",
        "    except KeyError:\n",
        "        return dict(total_revenue=0, avg_mrr_last3m=0, avg_mrr_last6m=0,\n",
        "                    mrr_trend=0, num_plan_changes=0, days_since_last_plan_change=999,\n",
        "                    current_mrr=0, is_downgraded=0)\n",
        "\n",
        "    subs = subs[subs['start_date'] < D]\n",
        "    if subs.empty:\n",
        "        return dict(total_revenue=0, avg_mrr_last3m=0, avg_mrr_last6m=0,\n",
        "                    mrr_trend=0, num_plan_changes=0, days_since_last_plan_change=999,\n",
        "                    current_mrr=0, is_downgraded=0)\n",
        "\n",
        "    total_revenue    = subs['mrr_amount'].sum()\n",
        "    current_mrr      = subs.iloc[-1]['mrr_amount']\n",
        "\n",
        "    last_3m  = subs[subs['start_date'] >= D - pd.Timedelta(days=90)]\n",
        "    last_6m  = subs[subs['start_date'] >= D - pd.Timedelta(days=180)]\n",
        "    prior_3m = subs[(subs['start_date'] >= D - pd.Timedelta(days=180)) &\n",
        "                    (subs['start_date'] < D - pd.Timedelta(days=90))]\n",
        "\n",
        "    avg_mrr_last3m = last_3m['mrr_amount'].mean() if not last_3m.empty else current_mrr\n",
        "    avg_mrr_last6m = last_6m['mrr_amount'].mean() if not last_6m.empty else current_mrr\n",
        "\n",
        "    # MRR trend: positive = growing, negative = declining\n",
        "    recent_mrr = last_3m['mrr_amount'].mean() if not last_3m.empty else 0\n",
        "    prior_mrr  = prior_3m['mrr_amount'].mean() if not prior_3m.empty else recent_mrr\n",
        "    mrr_trend  = (recent_mrr - prior_mrr) / (prior_mrr + 1)\n",
        "\n",
        "    num_plan_changes = max(0, len(subs) - 1)\n",
        "    last_plan_date   = subs['start_date'].max()\n",
        "    days_since_last_plan_change = (D - last_plan_date).days\n",
        "\n",
        "    # Downgrade signal: latest MRR < 6m ago MRR\n",
        "    is_downgraded = int(current_mrr < avg_mrr_last6m * 0.9)\n",
        "\n",
        "    return dict(total_revenue=total_revenue, avg_mrr_last3m=avg_mrr_last3m,\n",
        "                avg_mrr_last6m=avg_mrr_last6m, mrr_trend=mrr_trend,\n",
        "                num_plan_changes=num_plan_changes,\n",
        "                days_since_last_plan_change=days_since_last_plan_change,\n",
        "                current_mrr=current_mrr, is_downgraded=is_downgraded)\n",
        "\n",
        "\n",
        "def usage_features(account_id, D):\n",
        "    \"\"\"Feature usage signals up to snapshot date D.\"\"\"\n",
        "    try:\n",
        "        usage = df3_grp.get_group(account_id)\n",
        "    except KeyError:\n",
        "        return dict(avg_daily_events_7d=0, avg_daily_events_30d=0,\n",
        "                    avg_daily_events_60d=0, days_since_last_usage=999,\n",
        "                    num_features_used_30d=0, num_features_used_60d=0,\n",
        "                    usage_trend_30_vs_60=0, total_events_ever=0,\n",
        "                    days_active_ratio_30d=0, avg_session_duration_30d=0)\n",
        "\n",
        "    usage = usage[usage['usage_date'] < D]\n",
        "    if usage.empty:\n",
        "        return dict(avg_daily_events_7d=0, avg_daily_events_30d=0,\n",
        "                    avg_daily_events_60d=0, days_since_last_usage=999,\n",
        "                    num_features_used_30d=0, num_features_used_60d=0,\n",
        "                    usage_trend_30_vs_60=0, total_events_ever=0,\n",
        "                    days_active_ratio_30d=0, avg_session_duration_30d=0)\n",
        "\n",
        "    last_7d  = usage[usage['usage_date'] >= D - pd.Timedelta(days=7)]\n",
        "    last_30d = usage[usage['usage_date'] >= D - pd.Timedelta(days=30)]\n",
        "    last_60d = usage[usage['usage_date'] >= D - pd.Timedelta(days=60)]\n",
        "    prior_30d= usage[(usage['usage_date'] >= D - pd.Timedelta(days=60)) &\n",
        "                     (usage['usage_date'] <  D - pd.Timedelta(days=30))]\n",
        "\n",
        "    avg_daily_events_7d  = last_7d[EVENT_COL].sum()  / 7\n",
        "    avg_daily_events_30d = last_30d[EVENT_COL].sum() / 30\n",
        "    avg_daily_events_60d = last_60d[EVENT_COL].sum() / 60\n",
        "    days_since_last_usage = (D - usage['usage_date'].max()).days\n",
        "    num_features_used_30d = last_30d['feature_name'].nunique()\n",
        "    num_features_used_60d = last_60d['feature_name'].nunique()\n",
        "    total_events_ever     = usage[EVENT_COL].sum()\n",
        "\n",
        "    # Trend: recent vs prior 30d\n",
        "    recent_total = last_30d[EVENT_COL].sum()\n",
        "    prior_total  = prior_30d[EVENT_COL].sum()\n",
        "    usage_trend_30_vs_60 = (recent_total - prior_total) / (prior_total + 1)\n",
        "\n",
        "    # % of last 30 days with at least one event (engagement consistency)\n",
        "    active_days = last_30d['usage_date'].dt.date.nunique()\n",
        "    days_active_ratio_30d = active_days / 30.0\n",
        "\n",
        "    # Avg session duration (seconds) if column exists\n",
        "    dur_col = next((c for c in usage.columns if 'duration' in c.lower() or 'session' in c.lower()), None)\n",
        "    avg_session_duration_30d = last_30d[dur_col].mean() if dur_col and not last_30d.empty else 0\n",
        "    avg_session_duration_30d = avg_session_duration_30d if pd.notna(avg_session_duration_30d) else 0\n",
        "\n",
        "    return dict(avg_daily_events_7d=avg_daily_events_7d,\n",
        "                avg_daily_events_30d=avg_daily_events_30d,\n",
        "                avg_daily_events_60d=avg_daily_events_60d,\n",
        "                days_since_last_usage=days_since_last_usage,\n",
        "                num_features_used_30d=num_features_used_30d,\n",
        "                num_features_used_60d=num_features_used_60d,\n",
        "                usage_trend_30_vs_60=usage_trend_30_vs_60,\n",
        "                total_events_ever=total_events_ever,\n",
        "                days_active_ratio_30d=days_active_ratio_30d,\n",
        "                avg_session_duration_30d=avg_session_duration_30d)\n",
        "\n",
        "\n",
        "def support_features(account_id, D):\n",
        "    \"\"\"Support ticket signals up to snapshot date D.\"\"\"\n",
        "    try:\n",
        "        tickets = df4_grp.get_group(account_id)\n",
        "    except KeyError:\n",
        "        return dict(total_tickets_ever=0, num_tickets_30d=0, num_tickets_90d=0,\n",
        "                    avg_resolution_hours=0, avg_satisfaction=3.0,\n",
        "                    min_satisfaction=3.0, pct_escalated=0,\n",
        "                    num_high_priority_30d=0, days_since_last_ticket=999)\n",
        "\n",
        "    tickets = tickets[tickets[submit_col] < D]\n",
        "    if tickets.empty:\n",
        "        return dict(total_tickets_ever=0, num_tickets_30d=0, num_tickets_90d=0,\n",
        "                    avg_resolution_hours=0, avg_satisfaction=3.0,\n",
        "                    min_satisfaction=3.0, pct_escalated=0,\n",
        "                    num_high_priority_30d=0, days_since_last_ticket=999)\n",
        "\n",
        "    last_30d = tickets[tickets[submit_col] >= D - pd.Timedelta(days=30)]\n",
        "    last_90d = tickets[tickets[submit_col] >= D - pd.Timedelta(days=90)]\n",
        "\n",
        "    total_tickets_ever    = len(tickets)\n",
        "    num_tickets_30d       = len(last_30d)\n",
        "    num_tickets_90d       = len(last_90d)\n",
        "    avg_satisfaction      = tickets[sat_col].mean() if sat_col else 3.0\n",
        "    min_satisfaction      = tickets[sat_col].min()  if sat_col else 3.0\n",
        "    avg_resolution_hours  = tickets['resolution_hours'].mean() if 'resolution_hours' in tickets.columns else 0\n",
        "    avg_resolution_hours  = avg_resolution_hours if pd.notna(avg_resolution_hours) else 0\n",
        "    pct_escalated         = tickets[escalate_col].mean() if escalate_col else 0\n",
        "\n",
        "    # High priority tickets in last 30d\n",
        "    if priority_col and priority_col in tickets.columns:\n",
        "        hp = last_30d[last_30d[priority_col].str.lower().isin(['high', 'critical', 'urgent'])]\n",
        "        num_high_priority_30d = len(hp)\n",
        "    else:\n",
        "        num_high_priority_30d = 0\n",
        "\n",
        "    days_since_last_ticket = (D - tickets[submit_col].max()).days\n",
        "\n",
        "    return dict(total_tickets_ever=total_tickets_ever,\n",
        "                num_tickets_30d=num_tickets_30d,\n",
        "                num_tickets_90d=num_tickets_90d,\n",
        "                avg_resolution_hours=avg_resolution_hours,\n",
        "                avg_satisfaction=avg_satisfaction if pd.notna(avg_satisfaction) else 3.0,\n",
        "                min_satisfaction=min_satisfaction if pd.notna(min_satisfaction) else 3.0,\n",
        "                pct_escalated=float(pct_escalated),\n",
        "                num_high_priority_30d=num_high_priority_30d,\n",
        "                days_since_last_ticket=days_since_last_ticket)\n",
        "\n",
        "print(\"✅ All 3 feature functions defined (subscription, usage, support).\")\n",
        "print(f\"   Subscription features: 8\")\n",
        "print(f\"   Usage features: 10\")\n",
        "print(f\"   Support features: 9\")\n",
        "print(f\"   Account static features: 6\")\n",
        "print(f\"   Total features: ~33\")\n"
      ]
