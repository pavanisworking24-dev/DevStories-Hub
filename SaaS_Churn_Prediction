        "from tqdm import tqdm\n",
        "\n",
        "records = []\n",
        "PREDICTION_WINDOW = 30\n",
        "\n",
        "for _, row in tqdm(df1_clean.iterrows(), total=len(df1_clean), desc=\"Building snapshots\"):\n",
        "    acc_id      = row['account_id']\n",
        "    signup_date = row['signup_date']\n",
        "    churn_date  = churn_lookup.get(acc_id, None)\n",
        "\n",
        "    if pd.isna(signup_date):\n",
        "        continue\n",
        "\n",
        "    # Generate monthly snapshots\n",
        "    limit = pd.Timestamp(churn_date) if pd.notna(churn_date) else DATASET_END\n",
        "    snapshots = []\n",
        "    current = signup_date + relativedelta(months=1)\n",
        "    while current <= limit:\n",
        "        snapshots.append(current)\n",
        "        current += relativedelta(months=1)\n",
        "\n",
        "    for D in snapshots:\n",
        "        # Static account features\n",
        "        acct_feat = {\n",
        "            'account_id'       : acc_id,\n",
        "            'snapshot_date'    : D,\n",
        "            'industry'         : row['industry'],\n",
        "            'plan_tier'        : row['plan_tier'],\n",
        "            'country'          : row.get('country', 'Unknown'),\n",
        "            'referral_source'  : row.get('referral_source', 'Unknown'),\n",
