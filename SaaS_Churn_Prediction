          "text": [
            "Flask app saved to churn_model/app.py\n"
          ]
        }
      ],
      "source": [
        "flask_app = '''\n",
        "from flask import Flask, request, jsonify\n",
        "import joblib, pandas as pd, numpy as np\n",
        "\n",
        "app = Flask(__name__)\n",
        "model     = joblib.load(\"churn_model/lr_churn_model.pkl\") # Load LR model\n",
        "scaler    = joblib.load(\"churn_model/scaler.pkl\")       # Load scaler\n",
        "feat_names= joblib.load(\"churn_model/feature_names.pkl\")\n",
        "encoders  = joblib.load(\"churn_model/label_encoders.pkl\")\n",
        "threshold = joblib.load(\"churn_model/optimal_threshold.pkl\")\n",
        "\n",
        "@app.route(\"/predict\", methods=[\"POST\"])\n",
        "def predict():\n",
        "    data       = request.get_json()\n",
        "    account_id = data.get(\"account_id\", \"unknown\")\n",
        "    features   = data.get(\"features\", {})\n",
        "    row        = pd.DataFrame([features])\n",
        "\n",
        "    # Ensure all feature_names are present, fill missing with 0, and convert types\n",
        "    for col in feat_names:\n",
        "        if col not in row.columns:\n",
        "            row[col] = 0\n",
        "    row = row[feat_names].fillna(0).astype(float)\n",
        "\n",
        "    # Apply scaler to the incoming data\n",
        "    row_scaled = scaler.transform(row)\n",
        "\n",
        "    prob  = float(model.predict_proba(row_scaled)[0][1])\n",
        "    label = \"CHURN_RISK\" if prob >= threshold else \"ACTIVE\"\n",
        "    return jsonify({\"account_id\": account_id,\n",
        "                    \"churn_probability\": round(prob, 4),\n",
        "                    \"prediction\": label,\n",
        "                    \"threshold_used\": threshold})\n",
        "\n",
        "@app.route(\"/health\")\n",
        "def health(): return jsonify({\"status\": \"ok\"})\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    app.run(debug=True, host=\"0.0.0.0\", port=5000)\n",
        "'''\n",
        "with open('churn_model/app.py', 'w') as f:\n",
        "    f.write(flask_app)\n",
        "print(\"Flask app saved to churn_model/app.py\")"
      ]
