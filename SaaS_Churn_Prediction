        "from sklearn.model_selection import RandomizedSearchCV, StratifiedKFold\n",
        "from sklearn.linear_model import LogisticRegression\n",
        "from sklearn.metrics import make_scorer, recall_score, f1_score\n",
        "import numpy as np\n",
        "\n",
        "# ── Custom scorer: reward F1 ONLY when recall is in [0.72, 0.85] ──────────────\n",
        "# If recall is outside the window, the score is 0 so those params get deprioritised\n",
        "def recall_constrained_f1(y_true, y_prob):\n",
        "    \"\"\"Score = F1 if 0.72 ≤ recall ≤ 0.85, else penalised score.\"\"\"\n",
        "    # Try multiple thresholds and pick best recall-constrained F1\n",
        "    best = 0.0\n",
        "    for t in np.arange(0.10, 0.70, 0.02):\n",
        "        preds = (y_prob >= t).astype(int)\n",
        "        rec = recall_score(y_true, preds, zero_division=0)\n",
        "        f1  = f1_score(y_true, preds, zero_division=0)\n",
        "        if 0.72 <= rec <= 0.85:\n",
        "            best = max(best, f1)\n",
        "    return best\n",
        "\n",
        "custom_scorer = make_scorer(recall_constrained_f1, needs_proba=True, needs_threshold=False)\n",
        "\n",
        "# ── Parameter grid ─────────────────────────────────────────────────────────────\n",
        "param_dist = {\n",
        "    'C'       : [0.001, 0.005, 0.01, 0.05, 0.1, 0.5, 1.0, 5.0, 10.0],\n",
        "    'penalty' : ['l1', 'l2', 'elasticnet'],\n",
        "    'solver'  : ['saga'],          # saga supports all penalties including elasticnet\n",
        "    'l1_ratio': [0.1, 0.3, 0.5, 0.7, 0.9],  # only used when penalty='elasticnet'\n",
        "    'max_iter': [1000, 2000, 3000],\n",
        "}\n",
        "\n",
        "lr_base = LogisticRegression(\n",
        "    class_weight='balanced',   # handles imbalance at model level\n",
        "    random_state=42\n",
        ")\n",
        "\n",
        "cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n",
        "\n",
        "rs = RandomizedSearchCV(\n",
        "    lr_base, param_dist,\n",
        "    n_iter=40,\n",
        "    cv=cv,\n",
        "    scoring=custom_scorer,     # ← recall-constrained F1 scorer\n",
        "    n_jobs=-1,\n",
        "    random_state=42,\n",
        "    verbose=1,\n",
        "    error_score=0.0\n",
        ")\n",
        "\n",
