        "from imblearn.over_sampling import SMOTE\n",
        "from imblearn.combine import SMOTETomek\n",
        "\n",
        "# SMOTETomek: oversample minority + remove borderline majority noisy samples\n",
        "# Best choice for LR since it cleans overlap between classes\n",
        "smote_tomek = SMOTETomek(random_state=42)\n",
        "X_train_res, y_train_res = smote_tomek.fit_resample(X_train, y_train)\n",
        "\n",
        "print(f\"Before resampling : {dict(y_train.value_counts())}\")\n",
        "print(f\"After SMOTETomek  : {dict(pd.Series(y_train_res).value_counts())}\")\n",
        "print(f\"Resampled shape   : {X_train_res.shape}\")\n",
        "\n",
        "# Imbalance ratio from ORIGINAL train (used only for tree models, not LR)\n",
        "neg = (y_train == 0).sum()\n",
        "pos = (y_train == 1).sum()\n",
        "scale_pos_weight_orig = neg / pos\n",
        "print(f\"\\nOriginal class imbalance ratio: {scale_pos_weight_orig:.2f}:1\")\n",
        "print(\"LR will use class_weight='balanced' instead of this ratio.\")\n"
