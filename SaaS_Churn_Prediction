        "            'account_age_days' : (D - signup_date).days,\n",
        "        }\n",
        "\n",
        "        # Target: churned in next PREDICTION_WINDOW days?\n",
        "        if pd.notna(churn_date):\n",
        "            target = int(D < pd.Timestamp(churn_date) <= D + pd.Timedelta(days=PREDICTION_WINDOW))\n",
        "        else:\n",
        "            target = 0\n",
        "\n",
        "        record = {\n",
        "            **acct_feat,\n",
        "            **subscription_features(acc_id, D),\n",
        "            **usage_features(acc_id, D),\n",
