        "# ------------------------------------------------------------\n",
        "# Question 3: Do some subscriptions have sparse usage? (Days with no records)\n",
        "# ------------------------------------------------------------\n",
        "print(f\"\\n--- Question 3: Sparse Usage Analysis ---\")\n",
        "\n",
        "# Get total possible days in dataset\n",
        "total_days = (df3['usage_date'].max() - df3['usage_date'].min()).days + 1\n",
        "print(f\"Total days in dataset: {total_days}\")\n",
        "\n",
        "# Count active days per subscription\n",
        "active_days_per_sub = df3.groupby('subscription_id')['usage_date'].nunique().reset_index()\n",
        "active_days_per_sub.columns = ['subscription_id', 'active_days']\n",
        "active_days_per_sub['inactive_days'] = total_days - active_days_per_sub['active_days']\n",
        "active_days_per_sub['activity_ratio'] = active_days_per_sub['active_days'] / total_days\n",
        "\n",
        "print(\"\\nActive days per subscription:\")\n",
        "print(active_days_per_sub['active_days'].describe())\n",
        "\n",
        "# Categorize usage sparsity\n",
        "def categorize_usage(ratio):\n",
        "    if ratio >= 0.5:\n",
        "        return 'Frequent (>=50% days)'\n",
        "    elif ratio >= 0.2:\n",
        "        return 'Moderate (20-50% days)'\n",
        "    elif ratio >= 0.05:\n",
        "        return 'Sparse (5-20% days)'\n",
        "    else:\n",
        "        return 'Very Sparse (<5% days)'\n",
        "\n",
        "active_days_per_sub['usage_category'] = active_days_per_sub['activity_ratio'].apply(categorize_usage)"
