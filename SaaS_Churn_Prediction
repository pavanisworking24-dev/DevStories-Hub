        "else:\n",
        "    best_val_row = val_t_df.loc[val_t_df['f1'].idxmax()]\n",
        "    zone_label = \"best F1 (no recall constraint met)\"\n",
        "\n",
        "final_threshold = float(best_val_row['threshold'])\n",
        "print(f\"Threshold selected from validation: {final_threshold:.3f}  [{zone_label}]\")\n",
        "print(f\"  Val Recall   : {best_val_row['recall']:.4f}\")\n",
        "print(f\"  Val Precision: {best_val_row['precision']:.4f}\")\n",
        "print(f\"  Val F1       : {best_val_row['f1']:.4f}\")\n",
        "\n",
        "# ── Step 2: Apply to TEST set ────────────────────────────────────────────────\n",
        "y_test_prob = lr_tuned.predict_proba(X_test_scaled)[:, 1]\n",
        "y_test_pred = (y_test_prob >= final_threshold).astype(int)\n",
        "\n",
        "test_auc       = roc_auc_score(y_test, y_test_prob)\n",
        "test_prauc     = average_precision_score(y_test, y_test_prob)\n",
        "test_f1        = f1_score(y_test, y_test_pred)\n",
        "test_recall    = recall_score(y_test, y_test_pred)\n",
        "test_precision = precision_score(y_test, y_test_pred)\n",
        "\n",
        "print(\"\\n\" + \"=\"*60)\n",
        "print(\"  FINAL MODEL — TUNED LOGISTIC REGRESSION — TEST SET\")\n",
        "print(\"=\"*60)\n",
        "print(f\"  Threshold  : {final_threshold:.3f}  ({zone_label})\")\n",
        "print(f\"  ROC-AUC    : {test_auc:.4f}\")\n",
        "print(f\"  PR-AUC     : {test_prauc:.4f}\")\n",
        "print(f\"  F1-Score   : {test_f1:.4f}\")\n",
        "print(f\"  Recall     : {test_recall:.4f}  ← target 75–80%\")\n",
        "print(f\"  Precision  : {test_precision:.4f}\")\n",
        "print()\n",
        "print(classification_report(y_test, y_test_pred, target_names=['Active','Churner'], digits=4))\n",
        "\n",
        "# ── Step 3: Confusion matrix ────────────────────────────────────────────────\n",
        "cm = confusion_matrix(y_test, y_test_pred)\n",
        "disp = ConfusionMatrixDisplay(cm, display_labels=['Active','Churner'])\n",
        "disp.plot(colorbar=False, cmap='Blues')\n",
        "plt.title(f'Tuned Logistic Regression — Test Set  (threshold={final_threshold:.3f})')\n",
        "plt.tight_layout(); plt.show()\n",
        "\n",
        "# ── Step 4: Threshold sweep visualisation on test probs ─────────────────────\n",
        "test_records = []\n",
        "for t in thresholds_grid:\n",
        "    preds = (y_test_prob >= t).astype(int)\n",
        "    test_records.append({\n",
        "        'threshold': round(t, 3),\n",
        "        'recall'   : recall_score(y_test, preds, zero_division=0),\n",
        "        'precision': precision_score(y_test, preds, zero_division=0),\n",
        "        'f1'       : f1_score(y_test, preds, zero_division=0),\n",
        "    })\n",
        "test_t_df = pd.DataFrame(test_records)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(11, 5))\n",
        "ax.plot(test_t_df['threshold'], test_t_df['recall'],    color='red',    lw=2, label='Recall')\n",
        "ax.plot(test_t_df['threshold'], test_t_df['precision'], color='blue',   lw=2, label='Precision')\n",
        "ax.plot(test_t_df['threshold'], test_t_df['f1'],        color='purple', lw=2, label='F1-Score')\n",
        "ax.axhspan(0.75, 0.80, alpha=0.10, color='green', label='Target recall zone (75–80%)')\n",
        "ax.axvline(final_threshold, color='black', linestyle='--', lw=1.5,\n",
        "           label=f'Final threshold={final_threshold:.3f}')\n",
        "ax.set_xlabel('Threshold'); ax.set_ylabel('Score')\n",
        "ax.set_title('Tuned LR — Threshold vs Metrics (Test Set)')\n",
        "ax.legend(loc='upper right'); plt.tight_layout(); plt.show()\n",
        "\n",
        "# Save threshold for deployment\n",
        "best_t = final_threshold\n"
      ]
    },
