        "    y_prob  = model.predict_proba(X_input)[:, 1]\n",
        "\n",
        "    # Apply lower threshold for recall-focused prediction\n",
        "    y_pred  = (y_prob >= threshold).astype(int)\n",
        "\n",
        "    auc    = roc_auc_score(y, y_prob)\n",
        "    pr_auc = average_precision_score(y, y_prob)\n",
        "    f1     = f1_score(y, y_pred)\n",
        "\n",
        "    print(f\"\\n{'='*55}\")\n",
        "    print(f\"  {name}  (threshold={threshold})\")\n",
        "    print(f\"{'='*55}\")\n",
        "    print(f\"  ROC-AUC : {auc:.4f}\")\n",
        "    print(f\"  PR-AUC  : {pr_auc:.4f}\")\n",
        "    print(f\"  F1-Score: {f1:.4f}\")\n",
        "    print(classification_report(y, y_pred, target_names=['Active','Churner'], digits=4))\n",
        "\n",
        "    # ROC curve\n",
        "    if ax_roc is not None:\n",
        "        from sklearn.metrics import roc_curve\n",
        "        fpr, tpr, _ = roc_curve(y, y_prob)\n",
        "        ax_roc.plot(fpr, tpr, label=f'{name} (AUC={auc:.3f})', color=color, lw=2)\n",
        "\n",
        "    # PR curve\n",
        "    if ax_pr is not None:\n",
        "        prec, rec, _ = precision_recall_curve(y, y_prob)\n",
